# Club Management System - Environment Configuration Template
# Copy this file to .env and update the values

# Application Settings
APP_ENV=development          # Environment: development, production
PORT=8080                    # Application port

# Database Configuration
DB_HOST=db                   # Database host (use 'db' for Docker, 'localhost' for local)
DB_PORT=5432                 # PostgreSQL port
DB_USER=club_user           # Database username
DB_PASSWORD=CHANGE_ME       # Database password (use a strong password)
DB_NAME=club_management     # Database name
DB_SSLMODE=disable          # SSL mode: disable, require

# Session Configuration  
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING    # Secret key for session encryption (32+ characters)

# Local Development (uncomment when NOT using Docker)
# DB_HOST=localhost
# DB_PORT=5432
